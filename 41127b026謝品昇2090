#include <vector>

using namespace std;

class Solution {
public:
    vector<int> getAverages(vector<int>& nums, int k) 
    {
        int n = nums.size();
        vector<int> avgs(n, -1);
        
        int windowSize = 2 * k + 1;
        
        if (windowSize > n) 
        {
            return avgs;
        }
        
        long long windowSum = 0;

        for (int i = 0; i < windowSize; ++i) 
        {
            windowSum += nums[i];
        }

        avgs[k] = windowSum/windowSize;
        
        for (int i = k + 1; i < n - k; ++i) 
        {
            windowSum = windowSum - nums[i - k - 1] + nums[i + k];
            avgs[i] = windowSum/windowSize;
        }
        
        return avgs;
    }
};
